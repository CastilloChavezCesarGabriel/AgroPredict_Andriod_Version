<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AgroPredict" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_primary_dark</item>
        <item name="colorAccent">@color/green_accent</item>
        <item name="android:statusBarColor">@color/green_primary_dark</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:colorBackground">@color/surface</item>
    </style>

    <!-- Buttons -->

    <style name="AgroPredict.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/green_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/radius_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="AgroPredict.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/green_primary</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="cornerRadius">@dimen/radius_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="AgroPredict.Button.Tonal" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/soil_brown</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/radius_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- Text Inputs -->

    <style name="AgroPredict.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_medium</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_medium</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_medium</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_medium</item>
        <item name="boxStrokeColor">@color/outline</item>
    </style>

    <!-- Cards -->

    <style name="AgroPredict.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/radius_large</item>
        <item name="cardElevation">@dimen/elevation_low</item>
        <item name="contentPadding">@dimen/spacing_16</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
        <item name="cardBackgroundColor">@color/surface_elevated</item>
    </style>

    <style name="AgroPredict.Card.Hero" parent="AgroPredict.Card">
        <item name="cardBackgroundColor">@color/green_surface</item>
        <item name="strokeColor">@color/green_accent</item>
        <item name="cardElevation">@dimen/elevation_medium</item>
    </style>

    <!-- Spinner -->

    <style name="AgroPredict.Spinner" parent="android:Widget.Material.Spinner">
        <item name="android:background">@drawable/spinner_background</item>
        <item name="android:minHeight">@dimen/spinner_height</item>
        <item name="android:paddingStart">@dimen/spacing_16</item>
        <item name="android:paddingEnd">@dimen/spacing_16</item>
    </style>

    <!-- Toolbar -->

    <style name="AgroPredict.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/green_primary</item>
        <item name="titleTextColor">@color/white</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Text Appearances -->

    <style name="AgroPredict.Text" parent="">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="AgroPredict.Text.Display">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="AgroPredict.Text.Headline">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AgroPredict.Text.Title">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AgroPredict.Text.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingExtra">@dimen/line_spacing_body</item>
    </style>

    <style name="AgroPredict.Text.Label">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="AgroPredict.Text.CardTitle">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AgroPredict.Text.Link">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AgroPredict.Text.LinkSubtle">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

</resources>
