<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            style="@style/AgroPredict.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/home_title"
            app:titleTextColor="@color/white">

            <ImageButton
                android:id="@+id/btnLogout"
                android:layout_width="@dimen/icon_medium"
                android:layout_height="@dimen/icon_medium"
                android:layout_gravity="end"
                android:layout_marginEnd="@dimen/spacing_8"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/logout"
                android:padding="@dimen/spacing_8"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white" />

        </androidx.appcompat.widget.Toolbar>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNewPrediction"
                    style="@style/AgroPredict.Card.Hero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_16"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_20">

                        <ImageView
                            android:layout_width="@dimen/icon_large"
                            android:layout_height="@dimen/icon_large"
                            android:contentDescription="@string/new_prediction"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/green_primary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_16"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/AgroPredict.Text.Headline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/new_prediction"
                                android:textColor="@color/green_primary_dark" />

                            <TextView
                                style="@style/AgroPredict.Text.Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_4"
                                android:text="@string/new_prediction_description"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alignmentMode="alignBounds"
                    android:columnCount="2"
                    android:useDefaultMargins="true">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardHistory"
                        style="@style/AgroPredict.Card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            style="@style/AgroPredict.Text.CardTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:drawableTopCompat="@android:drawable/ic_menu_recent_history"
                            android:drawablePadding="@dimen/spacing_12"
                            app:drawableTint="@color/soil_brown"
                            android:gravity="center"
                            android:padding="@dimen/spacing_24"
                            android:text="@string/view_history" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardReport"
                        style="@style/AgroPredict.Card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            style="@style/AgroPredict.Text.CardTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:drawableTopCompat="@android:drawable/ic_menu_edit"
                            android:drawablePadding="@dimen/spacing_12"
                            app:drawableTint="@color/green_primary"
                            android:gravity="center"
                            android:padding="@dimen/spacing_24"
                            android:text="@string/generate_report" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPestGuide"
                        style="@style/AgroPredict.Card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            style="@style/AgroPredict.Text.CardTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:drawableTopCompat="@android:drawable/ic_menu_info_details"
                            android:drawablePadding="@dimen/spacing_12"
                            app:drawableTint="@color/soil_brown"
                            android:gravity="center"
                            android:padding="@dimen/spacing_24"
                            android:text="@string/pest_guide" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardResources"
                        style="@style/AgroPredict.Card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            style="@style/AgroPredict.Text.CardTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:drawableTopCompat="@android:drawable/ic_menu_mapmode"
                            android:drawablePadding="@dimen/spacing_12"
                            app:drawableTint="@color/green_primary"
                            android:gravity="center"
                            android:padding="@dimen/spacing_24"
                            android:text="@string/resources" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardManual"
                        style="@style/AgroPredict.Card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_columnSpan="2"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            style="@style/AgroPredict.Text.CardTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:drawableTopCompat="@android:drawable/ic_menu_agenda"
                            android:drawablePadding="@dimen/spacing_12"
                            app:drawableTint="@color/soil_brown"
                            android:gravity="center"
                            android:padding="@dimen/spacing_24"
                            android:text="@string/sustainable_manual" />

                    </com.google.android.material.card.MaterialCardView>

                </GridLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddField"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_24"
        android:contentDescription="@string/add_field"
        android:src="@android:drawable/ic_input_add"
        app:tint="@color/white"
        app:backgroundTint="@color/green_primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
