<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/AgroPredict.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/history_title"
        app:titleTextColor="@color/white" />

    <Spinner
        android:id="@+id/spnCropFilter"
        style="@style/AgroPredict.Spinner"
        android:layout_width="match_parent"
        android:layout_height="@dimen/spinner_height"
        android:layout_margin="@dimen/spacing_16" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ListView
            android:id="@+id/recyclerHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="@dimen/spacing_8"
            android:padding="@dimen/spacing_16" />

        <TextView
            android:id="@+id/tvEmptyState"
            style="@style/AgroPredict.Text.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/no_diagnostics"
            android:textColor="@color/text_tertiary"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
