<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/AgroPredict.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/report_title"
        app:titleTextColor="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16">

        <TextView
            style="@style/AgroPredict.Text.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:text="@string/select_crop"
            android:textColor="@color/text_secondary" />

        <Spinner
            android:id="@+id/spnCropSelection"
            style="@style/AgroPredict.Spinner"
            android:layout_width="match_parent"
            android:layout_height="@dimen/spinner_height"
            android:layout_marginBottom="@dimen/spacing_24" />

        <RadioGroup
            android:id="@+id/radioGroupFormat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_32"
            android:orientation="horizontal">

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radioPdf"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checked="true"
                android:text="@string/format_pdf"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radioCsv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/format_csv"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />

        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerate"
            style="@style/AgroPredict.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_16"
            android:text="@string/generate_button" />

        <ProgressBar
            android:id="@+id/progressGeneration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/spacing_16"
            android:indeterminateTint="@color/green_primary"
            android:visibility="invisible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShare"
            style="@style/AgroPredict.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/share_report"
            android:visibility="invisible" />

    </LinearLayout>

</LinearLayout>
