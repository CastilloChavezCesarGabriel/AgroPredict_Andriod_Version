<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/AgroPredict.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/field_detail_title"
        app:titleTextColor="@color/white">

        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="@dimen/icon_medium"
            android:layout_height="@dimen/icon_medium"
            android:layout_gravity="end"
            android:layout_marginEnd="@dimen/spacing_8"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/edit_field"
            android:padding="@dimen/spacing_8"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/white" />

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <ImageView
                android:id="@+id/ivCropPhoto"
                android:layout_width="match_parent"
                android:layout_height="@dimen/photo_height"
                android:layout_marginBottom="@dimen/spacing_16"
                android:background="@drawable/photo_placeholder"
                android:contentDescription="@string/crop_photo"
                android:scaleType="centerCrop" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCropInfo"
                style="@style/AgroPredict.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        style="@style/AgroPredict.Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_12"
                        android:text="@string/crop_info"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:id="@+id/tvCropType"
                        style="@style/AgroPredict.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/tvFieldName"
                        style="@style/AgroPredict.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/tvLocation"
                        style="@style/AgroPredict.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/tvPlantingDate"
                        style="@style/AgroPredict.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/tvSoilType"
                        style="@style/AgroPredict.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/tvStage"
                        style="@style/AgroPredict.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDiagnosticInfo"
                style="@style/AgroPredict.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        style="@style/AgroPredict.Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_12"
                        android:text="@string/diagnostic_info"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:id="@+id/tvConfidence"
                        style="@style/AgroPredict.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/tvSeverity"
                        style="@style/AgroPredict.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/tvDiagnosticDate"
                        style="@style/AgroPredict.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecommendations"
                style="@style/AgroPredict.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_24">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        style="@style/AgroPredict.Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_8"
                        android:text="@string/recommendations_label"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:id="@+id/tvRecommendations"
                        style="@style/AgroPredict.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewHistory"
                style="@style/AgroPredict.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_8"
                android:text="@string/view_change_history" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditField"
                style="@style/AgroPredict.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/edit_field" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
