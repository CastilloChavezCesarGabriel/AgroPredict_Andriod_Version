<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16">

        <ImageView
            android:id="@+id/ivCropPhoto"
            android:layout_width="match_parent"
            android:layout_height="@dimen/photo_height"
            android:background="@drawable/photo_placeholder"
            android:contentDescription="@string/crop_photo"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:layout_marginBottom="@dimen/spacing_20"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCapture"
                style="@style/AgroPredict.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_8"
                android:layout_weight="1"
                android:text="@string/capture_image" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGallery"
                style="@style/AgroPredict.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_8"
                android:layout_weight="1"
                android:text="@string/select_gallery" />

        </LinearLayout>

        <TextView
            style="@style/AgroPredict.Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:text="@string/crop_info" />

        <com.google.android.material.card.MaterialCardView
            style="@style/AgroPredict.Card.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCropType"
                    style="@style/AgroPredict.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_12"
                    android:hint="@string/crop_type_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCropType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilLocation"
                    style="@style/AgroPredict.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_12"
                    android:hint="@string/location_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />

                </com.google.android.material.textfield.TextInputLayout>

                <Spinner
                    android:id="@+id/spnSoilType"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <Spinner
                    android:id="@+id/spnStage"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPlantingDate"
                    style="@style/AgroPredict.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/planting_date_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPlantingDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:inputType="none" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/AgroPredict.Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:text="@string/environmental_conditions" />

        <com.google.android.material.card.MaterialCardView
            style="@style/AgroPredict.Card.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <Spinner
                    android:id="@+id/spnTemperature"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <Spinner
                    android:id="@+id/spnHumidity"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <Spinner
                    android:id="@+id/spnRain"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/AgroPredict.Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:text="@string/soil_conditions" />

        <com.google.android.material.card.MaterialCardView
            style="@style/AgroPredict.Card.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <Spinner
                    android:id="@+id/spnSoilMoisture"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <Spinner
                    android:id="@+id/spnSoilPH"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/AgroPredict.Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:text="@string/crop_management" />

        <com.google.android.material.card.MaterialCardView
            style="@style/AgroPredict.Card.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <Spinner
                    android:id="@+id/spnIrrigation"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <Spinner
                    android:id="@+id/spnFertilization"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <Spinner
                    android:id="@+id/spnSpraying"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <Spinner
                    android:id="@+id/spnWeeds"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/AgroPredict.Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:text="@string/symptoms" />

        <com.google.android.material.card.MaterialCardView
            style="@style/AgroPredict.Card.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_32">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <Spinner
                    android:id="@+id/spnSymptomType"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <Spinner
                    android:id="@+id/spnSeverity"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <Spinner
                    android:id="@+id/spnInsects"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <Spinner
                    android:id="@+id/spnAnimals"
                    style="@style/AgroPredict.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spinner_height" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitDiagnosis"
            style="@style/AgroPredict.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/submit_diagnosis" />

        <ProgressBar
            android:id="@+id/progressLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_16"
            android:indeterminateTint="@color/green_primary"
            android:visibility="invisible" />

    </LinearLayout>

</ScrollView>
